<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- App Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SyncWatch"
            android:textSize="32sp"
            android:textColor="#E94560"
            android:textStyle="bold"
            android:layout_marginTop="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="远程同步观影"
            android:textSize="16sp"
            android:textColor="#88FFFFFF"
            android:layout_marginBottom="32dp" />

        <!-- Server Config -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="服务器地址"
            android:textColor="#CCFFFFFF"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/et_server_url"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="ws://your-server-ip:8080"
            android:textColor="#FFFFFF"
            android:textColorHint="#55FFFFFF"
            android:textSize="14sp"
            android:background="@drawable/edit_text_bg"
            android:paddingHorizontal="16dp"
            android:inputType="textUri"
            android:singleLine="true" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="昵称"
            android:textColor="#CCFFFFFF"
            android:textSize="14sp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/et_nickname"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="输入你的昵称"
            android:textColor="#FFFFFF"
            android:textColorHint="#55FFFFFF"
            android:textSize="14sp"
            android:background="@drawable/edit_text_bg"
            android:paddingHorizontal="16dp"
            android:inputType="textPersonName"
            android:singleLine="true" />

        <!-- DLNA Section -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#33FFFFFF"
            android:layout_marginVertical="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📺 投屏接收"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tv_dlna_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="DLNA投屏服务未启动"
            android:textColor="#88FFFFFF"
            android:textSize="13sp"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btn_start_dlna"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="启动投屏服务"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:background="@drawable/btn_primary_bg"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btn_stop_dlna"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="停止投屏服务"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:background="@drawable/btn_danger_bg"
                android:layout_marginStart="8dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Video Section -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#33FFFFFF"
            android:layout_marginVertical="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎬 本地视频"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btn_pick_video"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="选择本地视频文件"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:background="@drawable/btn_secondary_bg" />

        <!-- Room Section -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#33FFFFFF"
            android:layout_marginVertical="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🏠 观影房间"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btn_create_room"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="创建房间（我是主机）"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/btn_accent_bg"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btn_join_room"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="加入房间（我是好友）"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:background="@drawable/btn_primary_bg"
            android:layout_marginBottom="16dp" />

        <!-- Join Room Panel (hidden by default) -->
        <LinearLayout
            android:id="@+id/layout_join"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="加入房间"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/et_room_id"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="房间号"
                android:textColor="#FFFFFF"
                android:textColorHint="#55FFFFFF"
                android:textSize="14sp"
                android:background="@drawable/edit_text_bg"
                android:paddingHorizontal="16dp"
                android:inputType="number"
                android:maxLength="8"
                android:singleLine="true"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_password"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="6位密码"
                android:textColor="#FFFFFF"
                android:textColorHint="#55FFFFFF"
                android:textSize="14sp"
                android:background="@drawable/edit_text_bg"
                android:paddingHorizontal="16dp"
                android:inputType="numberPassword"
                android:maxLength="6"
                android:singleLine="true"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_cancel_join"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="取消"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/btn_secondary_bg"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/btn_confirm_join"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="加入"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/btn_primary_bg"
                    android:layout_marginStart="8dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Room Info -->
        <TextView
            android:id="@+id/tv_room_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#88FFFFFF"
            android:textSize="13sp"
            android:layout_marginTop="12dp" />

        <View
            android:layout_width="1dp"
            android:layout_height="32dp" />

    </LinearLayout>
</ScrollView>
